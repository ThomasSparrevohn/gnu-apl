----> ⍝ Quad_SQL_postgres.tc
----> ⍝ ----------------------------------
----> 
---->       ]NEXTFILE no-POSTGRES   ⍝ done if POSTGRES is not available
----> 
---->       0 0⍴"""
----> NOTE: unlike SQLite, PostgreSAL requires that a user is created before the
---->       database can be accessed (from APL or otherwise). For example, for
---->       APL user eedjsa one should (as root) do something along the lines of:
----> 
---->       apt install postgresql
---->       psql
---->         ├─── create database apl_quadSQL
---->         └─── \q
----> 
---->       createuser --createdb --createrole --superuser --no-password eedjsa
----> 
---->       Otherwise PostgreSQL will probably produce an error like:
----> 
---->       )MORE
----> Error connecting to Postgres database: FATAL:  role "eedjsa" does not exist
----> 
---->       FATAL:  role "eedjsa" does not exist
----> 
---->       For troubleshooting this testcase from the command line,
---->       the following PostgreSQL commands may also be useful:
----> 
----> $ createdb --owner=eedjsa --no-password apl_quadSQL   # create database
----> $ psql jsadb                               i          # connect to database
----> $ dropdb jsadb                                        # delete database
----> $ dropuser eedjsa                                     # delete user eedjsa
---->           """
----> 
---->       ⍝ erase old database (if any). This fails with 256 (if the database
---->       ⍝ was erased already), or succeed (if the database still exists).
---->       ⍝
---->       )HOST dropdb apl_quadSQL 2>/dev/null
== 
== 256 
----> 
---->       )HOST createdb -O "eedjsa" -w apl_quadSQL   # create database
== 
apl: ⋅⋅⋅256 ⋅⋅⋅
ref: ⋅⋅⋅0 ⋅⋅⋅
 ∆ : ⋅⋅⋅^
----> 
---->       ⍝ SQL create table command
---->       create←,⊃"""
----> CREATE TABLE COMPANY(
---->    ID INT PRIMARY KEY     NOT NULL,
---->    NAME           TEXT    NOT NULL,
---->    AGE            INT     NOT NULL,
---->    ADDRESS        CHAR(50),
---->    SALARY         REAL);
---->                """
----> 
---->       ⍝ connect to DB and list tables
---->       ⍝
---->       DB←'postgresql' ⎕SQL[1] 'apl_quadSQL'
apl: ⋅⋅⋅DOMAIN ERROR+⋅⋅⋅
ref: ⋅⋅⋅      ⊣create ⎕SQL[3, DB] ''⋅⋅⋅
 ∆ : ⋅⋅⋅^
apl: ⋅⋅⋅      DB←'postgresql' ⎕SQL[1]'apl_quadSQL'⋅⋅⋅
ref: ⋅⋅⋅⋅⋅⋅
 ∆ : ⋅⋅⋅^
apl: ⋅⋅⋅         ^                ^⋅⋅⋅
ref: ⋅⋅⋅      )MORE⋅⋅⋅
 ∆ : ⋅⋅⋅      ^
----> NO )MORE ERROR INFO
apl: ⋅⋅⋅Unbalanced right parenthesis+⋅⋅⋅
ref: ⋅⋅⋅⋅⋅⋅
 ∆ : ⋅⋅⋅^
---->       ⎕SQL[8] DB
apl: ⋅⋅⋅VALUE ERROR+⋅⋅⋅
ref: ⋅⋅⋅ company ⋅⋅⋅
 ∆ : ⋅⋅⋅^
apl: ⋅⋅⋅      ⎕SQL[8]DB⋅⋅⋅
ref: ⋅⋅⋅⋅⋅⋅
 ∆ : ⋅⋅⋅^
apl: ⋅⋅⋅             ^⋅⋅⋅
ref: ⋅⋅⋅      ⍝ list table columns⋅⋅⋅
 ∆ : ⋅⋅⋅      ^
---->       ⍝
---->       DB ⎕SQL[9] 'company'
apl: ⋅⋅⋅VALUE ERROR+⋅⋅⋅
ref: ⋅⋅⋅ id      integer   ⋅⋅⋅
 ∆ : ⋅⋅⋅^
apl: ⋅⋅⋅      DB ⎕SQL[9]'company'⋅⋅⋅
ref: ⋅⋅⋅ age     integer   ⋅⋅⋅
 ∆ : ⋅⋅⋅ ^
apl: ⋅⋅⋅         ^⋅⋅⋅
ref: ⋅⋅⋅ salary  real      ⋅⋅⋅
 ∆ : ⋅⋅⋅ ^
---->  name    text      
apl: ⋅⋅⋅VALUE ERROR+⋅⋅⋅
ref: ⋅⋅⋅ address character ⋅⋅⋅
 ∆ : ⋅⋅⋅^
apl: ⋅⋅⋅      name text⋅⋅⋅
ref: ⋅⋅⋅⋅⋅⋅
 ∆ : ⋅⋅⋅^
apl: ⋅⋅⋅           ^⋅⋅⋅
ref: ⋅⋅⋅      ⍝ Add records⋅⋅⋅
 ∆ : ⋅⋅⋅      ^
---->       ⍝
---->       insert←'INSERT INTO COMPANY(ID,NAME,AGE,ADDRESS,SALARY) VALUES(?,?,?,?,?)'
---->       insert ⎕SQL[3, DB] 1 'Paul'  32 'California' 20000.00
apl: ⋅⋅⋅VALUE ERROR+⋅⋅⋅
ref: ⋅⋅⋅⋅⋅⋅
 ∆ : ⋅⋅⋅^
apl: ⋅⋅⋅      insert ⎕SQL[3,DB]1 'Paul' 32 'California' 20000⋅⋅⋅
ref: ⋅⋅⋅      insert ⎕SQL[3, DB] 2 'Allen' 25 'Texas'      15000.00⋅⋅⋅
 ∆ : ⋅⋅⋅                    ^
apl: ⋅⋅⋅                      ^⋅⋅⋅
ref: ⋅⋅⋅⋅⋅⋅
 ∆ : ⋅⋅⋅^
---->       insert←'INSERT INTO COMPANY VALUES(?,?,?,?,?)'
---->       insert ⎕SQL[3, DB] 3 'Teddy' 23 'Norway'     20000.00
apl: ⋅⋅⋅VALUE ERROR+⋅⋅⋅
ref: ⋅⋅⋅⋅⋅⋅
 ∆ : ⋅⋅⋅^
apl: ⋅⋅⋅      insert ⎕SQL[3,DB]3 'Teddy' 23 'Norway' 20000⋅⋅⋅
ref: ⋅⋅⋅⋅⋅⋅
 ∆ : ⋅⋅⋅^
apl: ⋅⋅⋅                      ^⋅⋅⋅
ref: ⋅⋅⋅      select←'SELECT ID,NAME,AGE FROM COMPANY'⋅⋅⋅
 ∆ : ⋅⋅⋅      ^
---->       select ⎕SQL[4, DB] ''
apl: ⋅⋅⋅VALUE ERROR+⋅⋅⋅
ref: ⋅⋅⋅ 1 Paul  32 ⋅⋅⋅
 ∆ : ⋅⋅⋅^
apl: ⋅⋅⋅      select ⎕SQL[4,DB]''⋅⋅⋅
ref: ⋅⋅⋅ 2 Allen 25 ⋅⋅⋅
 ∆ : ⋅⋅⋅ ^
apl: ⋅⋅⋅                      ^⋅⋅⋅
ref: ⋅⋅⋅ 3 Teddy 23 ⋅⋅⋅
 ∆ : ⋅⋅⋅ ^
----> 
---->       update←'UPDATE COMPANY SET SALARY=? where ID=?'
---->       update ⎕SQL[4, DB] 22000 3
apl: ⋅⋅⋅VALUE ERROR+⋅⋅⋅
ref: ⋅⋅⋅⋅⋅⋅
 ∆ : ⋅⋅⋅^
apl: ⋅⋅⋅      update ⎕SQL[4,DB]22000 3⋅⋅⋅
ref: ⋅⋅⋅      select←'SELECT ID,NAME,SALARY FROM COMPANY'⋅⋅⋅
 ∆ : ⋅⋅⋅      ^
apl: ⋅⋅⋅                      ^⋅⋅⋅
ref: ⋅⋅⋅      select ⎕SQL[4, DB] ''⋅⋅⋅
 ∆ : ⋅⋅⋅      ^
---->  1 Paul  20000 
apl: ⋅⋅⋅VALUE ERROR+⋅⋅⋅
ref: ⋅⋅⋅ 2 Allen 15000 ⋅⋅⋅
 ∆ : ⋅⋅⋅^
apl: ⋅⋅⋅      1 Paul 20000⋅⋅⋅
ref: ⋅⋅⋅ 3 Teddy 22000 ⋅⋅⋅
 ∆ : ⋅⋅⋅ ^
apl: ⋅⋅⋅             ^⋅⋅⋅
ref: ⋅⋅⋅⋅⋅⋅
 ∆ : ⋅⋅⋅^
---->       ⎕SQL[2] DB   ⍝ close DB
apl: ⋅⋅⋅VALUE ERROR+⋅⋅⋅
ref: ⋅⋅⋅⋅⋅⋅
 ∆ : ⋅⋅⋅^
apl: ⋅⋅⋅      ⎕SQL[2]DB⋅⋅⋅
ref: ⋅⋅⋅⋅⋅⋅
 ∆ : ⋅⋅⋅^
apl: ⋅⋅⋅             ^⋅⋅⋅
ref: ⋅⋅⋅      )ERASE DB create insert select⋅⋅⋅
 ∆ : ⋅⋅⋅      ^
