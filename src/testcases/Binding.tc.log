----> вЌќ IBM APL2 compatibility ----------------------------------
----> 
---->       в€‡Zв†ђSHOW_NC BВЇB;N
---->        Nв†ђ8в†‘B,':'
---->        в†’(ВЇ1 0 1 2 3 4 = вЋ•NC BВЇB)/I U L V F O в—Љ ++
---->       I: в†’0, Zв†ђ(8в†‘B), ': Invalid Name'
---->       U: в†’0, Zв†ђ(8в†‘B), ': Unused Name'
---->       L: в†’0, Zв†ђ(8в†‘B), ': Label'
---->       V: в†’0, Zв†ђ(8в†‘B), ': Value', вЌЋBВЇB
---->       F: в†’0, Zв†ђ(8в†‘B), ': Function'
---->       O: в†’0, Zв†ђ(8в†‘B), ': Operator'
---->       в€‡
----> 
---->       в€‡Zв†ђA (LO OPER1) B
