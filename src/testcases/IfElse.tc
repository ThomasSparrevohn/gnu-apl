main: Parse error+
      )MORE
empty тЖТтЖТ ... тЖРтЖТ (aka. empty THEN)
      )SIC
      )CHECK BRIEF


      0 тЖТтЖТ 'True' тЖРтЖТ тЖРтЖР   тНЭ empty ELSE
main: Parse error+
      )MORE
empty тЖРтЖТ ... тЖРтЖР (aka. empty ELSE)
      )SIC
      )CHECK BRIEF
      

            0 тЖТтЖТ 'True' тЖРтЖТ тЖРтЖР   тНЭ empty ELSE
main: Parse error+
      )MORE
empty тЖРтЖТ ... тЖРтЖР (aka. empty ELSE)
      )SIC
      )CHECK BRIEF


      0 тЖТтЖТ тЖРтЖТ тЖРтЖР           тНЭ empty THEN and ELSE
main: Parse error+
      )MORE
empty тЖТтЖТ ... тЖРтЖТ (aka. empty THEN)
      )SIC
      )CHECK BRIEF


      тНЭ functions
      тНЭ
      )ERASE FOO

тИЗFOO COND
[1] 'Line 1 (if-else-endif)'
[2] COND    тЖТтЖТ
[3] 'TRUE'  тЖРтЖТ
[4] 'FALSE' тЖРтЖР
[5]  'Line 5' COND
тИЗ

      )SIC
      )CHECK BRIEF

      FOO 0
Line 1 (if-else-endif)
FALSE
 Line 5 0 

      FOO 1
Line 1 (if-else-endif)
TRUE
 Line 5 1 

      )MORE
NO )MORE ERROR INFO

      )SIC
      )CHECK BRIEF

      )ERASE FOO

тИЗFOO COND
[1]  'Line 1 (if-endif)'
[2]  COND   тЖТтЖТ
[3]  'TRUE' тЖРтЖР
[4]  'Line 4' COND
тИЗ

      )CHECK BRIEF

      FOO 0
Line 1 (if-endif)
 Line 4 0 

      FOO 1
Line 1 (if-endif)
TRUE
 Line 4 1 

      )ERASE FOO

тИЗFOO COND
[1] 'Line 1 (single line if-else-endif)'
[2] COND тЖТтЖТ 'TRUE' тЖРтЖТ 'FALSE' тЖРтЖР
[3]  'Line 3' COND
тИЗ

      FOO 0
Line 1 (single line if-else-endif)
FALSE
 Line 3 0 

      FOO 1
Line 1 (single line if-else-endif)
TRUE
 Line 3 1 

      )MORE
NO )MORE ERROR INFO

