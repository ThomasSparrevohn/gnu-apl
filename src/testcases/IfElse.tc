тНЭ IfElse.tc

  тНЭ   ]log 9  ON   тНЭ fix logging
  тНЭ   ]log 48 ON   тНЭ IfElse logging

      тНЭ test various COND тЖТтЖТ THEN тЖРтЖТ ELSE тЖРтЖР cases

      тНЭ test COND variants (primarily error conditions)
      тНЭ
      2 тЖТтЖТ 'True' тЖРтЖТ 'False' тЖРтЖР
DOMAIN ERROR+
      2
      ^
      )MORE
In B тЖРтЖР ... тЖТтЖТ : condition B is not Boolean
      )SIC
      )CHECK BRIEF


      1+1 тЖТтЖТ 'True' тЖРтЖТ 'False' тЖРтЖР
DOMAIN ERROR+
      1+1
      ^
      )MORE
In B тЖРтЖР ... тЖТтЖТ : condition B is not Boolean
      )SIC
      )CHECK BRIEF


      1 1 тЖТтЖТ 'True' тЖРтЖТ 'False' тЖРтЖР
LENGTH ERROR+
      1 1
      ^
      )MORE
In B тЖРтЖР ... тЖТтЖТ : condition B is too long
      )SIC
      )CHECK BRIEF


      ''  тЖТтЖТ 'True' тЖРтЖТ 'False' тЖРтЖР
LENGTH ERROR+
      ''
      ^
      )MORE
In B тЖРтЖР ... тЖТтЖТ : condition B is empty
      )SIC
      )CHECK BRIEF


      тНЭ test COND TRUE variants
      тНЭ
      1 тЖТтЖТ 'True' тЖРтЖТ 'False' тЖРтЖР
True
      1 тЖТтЖТ 1+1 тЖРтЖТ 'False' тЖРтЖР
2
      1 тЖТтЖТ тЖРтЖТ 'False' тЖРтЖР   тНЭ empty THEN
main: Parse error+
      )MORE
empty тЖТтЖТ ... тЖРтЖТ (aka. empty THEN)
      )SIC
      )CHECK BRIEF


      1 тЖТтЖТ 'True' тЖРтЖТ  тЖРтЖР   тНЭ empty ELSE
main: Parse error+
      )MORE
empty тЖРтЖТ ... тЖРтЖР (aka. empty ELSE)
      )SIC
      )CHECK BRIEF

      1 тЖТтЖТ тЖРтЖТ тЖРтЖР           тНЭ empty THEN and ELSE
main: Parse error+
      )MORE
empty тЖТтЖТ ... тЖРтЖТ (aka. empty THEN)
      )SIC
      )CHECK BRIEF


