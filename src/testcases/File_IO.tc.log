---->       SOCK_STREAM ← 1           ⍝ see /usr/include/.../bits/socket_type.h
---->       IPPROTO_IP       ← 0      ⍝ see /usr/include/netinet/in.h
---->       LOCALHOST←256⊥127 0 0 1   ⍝ 127.0.0.1 in host byte order
